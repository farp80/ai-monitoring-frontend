# Leave empty to proxy /api to FastAPI via vite.config.ts (localhost:8000)
VITE_API_BASE_URL=

# true = local mock OAuth + session (no provider apps required)
VITE_AUTH_MOCK=true

# OAuth client IDs (redirect URI: http://localhost:5173/auth/callback)
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
VITE_YAHOO_CLIENT_ID=
